{
  "name": "qa-playwright-ts-saucedemo",
  "version": "1.0.0",
  "description": "Student-friendly Playwright and TypeScript QA automation learning repo for Sauce Demo.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://www.saucedemo.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codezelaca/qa-playwright-ts-saucedemo.git"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa-automation",
    "saucedemo",
    "codezela-career-accelerator"
  ],
  "author": "Codezela Career Accelerator",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/codezelaca/qa-playwright-ts-saucedemo/issues"
  },
  "homepage": "https://github.com/codezelaca/qa-playwright-ts-saucedemo#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0"
  }
}
